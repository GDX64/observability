{
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "isolatedModules": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "outDir": "./dist-ts"
  }
}
